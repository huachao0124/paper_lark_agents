# CodeBuddy Feishu bot profile.

PLA_LARK_PROFILE=codebuddy
PLA_AGENT_MODE=codebuddy
PLA_BOT_ALIASES=CodeBuddy,codebuddy
# Set to true when this bridge runs alongside Codex/Claude/GPT-Pro in the
# same Feishu group; each instance responds only to its own alias.
PLA_STRICT_ALIAS_ROUTING=true
PLA_SESSION_SUFFIX=

# Leave empty to let CodeBuddy respond in any Feishu group where this bot is added.
# Fill oc_xxx only if you want to lock it to one group.
PLA_CHAT_ID=
PLA_BOT_OPEN_ID=
PLA_WORKSPACE=/apdcephfs_sgfd/share_303735497/yixianliu/arimazhu
PLA_WORKSPACE_ROOTS=/apdcephfs_sgfd/share_303735497/yixianliu/arimazhu
PLA_HANDLE_MANAGEMENT_COMMANDS=false
PLA_LARK_CLI=lark-cli
PLA_EVENT_KEY=im.message.receive_v1
PLA_EVENT_KEYS=im.message.receive_v1,im.chat.member.bot.added_v1
PLA_PROXY_URL=http://star-proxy.oa.com:3128
PLA_AGENT_PROXY_URL=http://127.0.0.1:7899
PLA_NO_PROXY=localhost,127.0.0.1,::1

PLA_CODEBUDDY_CMD=codebuddy
PLA_CODEBUDDY_ARGS=-p --output-format text
PLA_CODEBUDDY_RUNTIME=session
PLA_CODEBUDDY_SESSION_ARGS=--permission-mode acceptEdits
PLA_CODEBUDDY_STARTUP_COMMANDS=
PLA_CODEBUDDY_MODEL=
PLA_CODEBUDDY_DEFAULT_EFFORT=xhigh
PLA_CODEBUDDY_TIMEOUT=900

PLA_ENABLE_TASKS=false
PLA_ENABLE_DEBATE=false
PLA_RESPOND_TO_ALL=true
PLA_DEFAULT_RESPONDER=both
PLA_SEND_PROGRESS=true
PLA_DASHBOARD_ENABLED=false
PLA_DASHBOARD_TAB_ENABLED=false
PLA_MAX_MESSAGE_CHARS=3500
PLA_ENABLE_ARTIFACTS=true
PLA_MAX_ARTIFACTS=8
PLA_ENABLE_INBOUND_FILES=true
PLA_MAX_INBOUND_FILES=8
PLA_MAX_EVENT_AGE_SECONDS=3600
PLA_STATUS_UPDATE_SECONDS=1

# Per-Feishu-group research room memory.
PLA_ENABLE_MEMORY=true
PLA_STATE_DIR=.state
PLA_MEMORY_TURNS=24
PLA_MEMORY_CHARS=9000
PLA_OUTBOX_TTL_SECONDS=86400
PLA_ENABLE_AGENT_DISCUSSION=true
PLA_DIRECT_AGENT_HANDOFF=true
PLA_MAX_AGENT_DISCUSSION_TURNS=6
PLA_AGENT_DISCUSSION_WINDOW_SECONDS=600
PLA_NO_REPLY_TOKEN=[NO_REPLY]
PLA_SESSION_STARTUP_WAIT=12
PLA_SESSION_CAPTURE_LINES=4000
PLA_SESSION_HISTORY_LIMIT=50000
PLA_SESSION_COLUMNS=240
PLA_SESSION_ROWS=200
