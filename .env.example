# Copy to .env and edit.

# Only respond in this chat. Leave empty to respond in every group the bot can see.
PLA_CHAT_ID=

# Optional: ignore messages sent by the bot itself.
PLA_BOT_OPEN_ID=

# Where Codex/Claude should run from.
PLA_WORKSPACE=/apdcephfs_sgfd/share_303735497/yixianliu/arimazhu
PLA_WORKSPACE_WARMUP_AGENTS=

# Feishu CLI command.
PLA_LARK_CLI=lark-cli

# Optional lark-cli profile. Use this when you create separate Feishu apps for
# Codex and Claude Code.
PLA_LARK_PROFILE=

# Which assistant this process represents: codex, claude, both, or tasks.
PLA_AGENT_MODE=both

# Display names that should trigger this bot when mentioned in Feishu.
# Examples: Codex or Claude Code,Claude
PLA_BOT_ALIASES=

# Event source. im.message.receive_v1 requires the event to be enabled in the
# Feishu developer console for your app.
PLA_EVENT_KEY=im.message.receive_v1
PLA_EVENT_KEYS=im.message.receive_v1,im.chat.member.bot.added_v1
PLA_PROXY_URL=http://star-proxy.oa.com:3128
PLA_AGENT_PROXY_URL=http://127.0.0.1:7899
PLA_NO_PROXY=localhost,127.0.0.1,::1

# Agent commands. The default Codex command reads the prompt from stdin via "-".
PLA_CODEX_CMD=codex
PLA_CODEX_ARGS=exec --skip-git-repo-check -
PLA_CODEX_RUNTIME=session
PLA_CODEX_SESSION_ARGS=--no-alt-screen
PLA_CODEX_STARTUP_COMMANDS=/permissions auto-review
PLA_CODEX_MODEL=
PLA_CODEX_DEFAULT_EFFORT=
PLA_CODEX_TIMEOUT=900

PLA_CLAUDE_CMD=claude
CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1
PLA_CLAUDE_ARGS=-p --output-format text
PLA_CLAUDE_RUNTIME=session
PLA_CLAUDE_SESSION_ARGS=--permission-mode auto --teammate-mode in-process
PLA_CLAUDE_MODEL=
PLA_CLAUDE_DEFAULT_EFFORT=
PLA_CLAUDE_TIMEOUT=900

# Feishu Tasks. User identity is often better for personal tasklists.
PLA_TASK_AS=user
PLA_TASKLIST_ID=
PLA_ENABLE_TASKS=true
PLA_ENABLE_DEBATE=true

# Safety and formatting.
PLA_RESPOND_TO_ALL=false
# Who answers unaddressed group messages when RESPOND_TO_ALL is on: codex,
# claude, or both. Override per group from Feishu with /responder.
PLA_DEFAULT_RESPONDER=both
PLA_SEND_PROGRESS=true
PLA_DASHBOARD_ENABLED=false
PLA_DASHBOARD_PUBLIC_URL=
PLA_DASHBOARD_TAB_ENABLED=true
PLA_DASHBOARD_TAB_NAME=AI 状态
PLA_MAX_MESSAGE_CHARS=3500
PLA_ENABLE_ARTIFACTS=true
PLA_MAX_ARTIFACTS=8
PLA_ENABLE_INBOUND_FILES=true
PLA_MAX_INBOUND_FILES=8
PLA_STATUS_UPDATE_SECONDS=1
PLA_ENABLE_AGENT_DISCUSSION=true
PLA_DIRECT_AGENT_HANDOFF=true
PLA_MAX_AGENT_DISCUSSION_TURNS=6
PLA_AGENT_DISCUSSION_WINDOW_SECONDS=600

PLA_SESSION_STARTUP_WAIT=12
PLA_SESSION_CAPTURE_LINES=20000
PLA_SESSION_HISTORY_LIMIT=50000
PLA_SESSION_COLUMNS=240
PLA_SESSION_ROWS=200
